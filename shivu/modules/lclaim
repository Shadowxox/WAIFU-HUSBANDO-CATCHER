from telegram import Update, InlineKeyboardMarkup, InlineKeyboardButton
from telegram.ext import CallbackContext, CommandHandler
from datetime import datetime, timedelta
from shivu import application, waifu_collection, user_collection

ALLOWED_GROUP_ID = -1002643948280  # Replace with your group ID
GROUP_LINK = "https://t.me/hwkwjieie"  # Replace with your group link

async def hclaim(update: Update, context: CallbackContext):
    chat_id = update.effective_chat.id
    user_id = update.effective_user.id

    if chat_id != ALLOWED_GROUP_ID:
        button = InlineKeyboardMarkup([[InlineKeyboardButton("Join Here", url=GROUP_LINK)]])
        await update.message.reply_text(
            "🔔 ᴊᴏɪɴ ᴛʜᴇ ᴄʜᴀɴɴᴇʟ ᴛᴏ ᴄʟᴀɪᴍ ʏᴏᴜʀ Dᴀɪʟʏ ᴄʜᴀʀᴀᴄᴛᴇʀ 🔔",
            reply_markup=button
        )
        return

    user_data = await user_collection.find_one({"user_id": user_id})
    now = datetime.utcnow()

    if user_data and "last_claim" in user_data:
        last_claim = user_data["last_claim"]
        if now - last_claim < timedelta(hours=24):
            remaining = timedelta(hours=24) - (now - last_claim)
            hours, remainder = divmod(remaining.seconds, 3600)
            minutes, _ = divmod(remainder, 60)
            await update.message.reply_text(
                f"⏳ You can claim your next waifu in {hours}h {minutes}m."
            )
            return

    waifu = await waifu_collection.aggregate([{"$sample": {"size": 1}}]).to_list(length=1)
    if not waifu:
        await update.message.reply_text("No waifus available at the moment.")
        return

    waifu = waifu[0]
    await user_collection.update_one(
        {"user_id": user_id},
        {"$set": {"last_claim": now}},
        upsert=True
    )

    caption = (
        f"🎉 You have claimed a waifu!\n\n"
        f"👤 Name: {waifu['name']}\n"
        f"📺 Anime: {waifu['anime']}\n"
        f"💎 Rarity: {waifu['rarity']}\n"
        f"🆔 ID: {waifu['id']}"
    )

    await update.message.reply_photo(photo=waifu["img_url"], caption=caption)

application.add_handler(CommandHandler("lclaim", lclaim))
